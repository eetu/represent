{
	"name": "represent-frontend",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"validate": "yarn typecheck && yarn lint && yarn format"
	},
	"dependencies": {
		"dompurify": "^3.4.12",
		"marked": "^18.0.6",
		"mermaid": "^11.16.0"
	},
	"devDependencies": {
		"@anarkisti/eslint-config": "^1.1.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^26",
		"eslint": "^10.7.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"typescript": "^6.0.2",
		"vite": "^8.1.5"
	},
	"packageManager": "yarn@4.16.0"
}
