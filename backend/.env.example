# Local dev config — cp .env.example .env (gitignored), run from backend/
# (`bacon` or `cargo run`). bacon watches .env and restarts on change.
# All optional; defaults in src/config.rs. Prod gets env from the quadlet.

# Dev auth: requests without a session get a synthetic `dev` identity, and
# /auth/login?username=alice mints arbitrary dev sessions (multi-user
# testing). Never in prod.
DEV_AUTH=1

# Serve the built SPA from the sibling frontend (yarn build). With the Vite
# dev server (yarn dev on :5173) the proxy talks to :3008 either way.
STATIC_DIR=../frontend/dist

# All durable state: one SQLite file (repo root, gitignored).
REPRESENT_DB_PATH=../represent.db

# One-shot import of the legacy flat-file layout into a profile (both vars
# required; already-existing projects are skipped — safe to leave set).
# REPRESENT_IMPORT_DIR=../data
# REPRESENT_IMPORT_EMAIL=dev@localhost

# Signed-cookie key, required when DEV_AUTH is off (`openssl rand -hex 64`).
# SESSION_KEY=

# Own OIDC login (kanidm). All four required to enable; unset → forward-auth
# headers (oauth2-proxy) or DEV_AUTH carry the identity instead.
# OIDC_ISSUER=https://kanidm.example.com/oauth2/openid/represent
# OIDC_CLIENT_ID=represent
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://represent.example.com/auth/callback

# REPRESENT_BIND=0.0.0.0:3008
# RUST_LOG=info,represent_backend=debug
